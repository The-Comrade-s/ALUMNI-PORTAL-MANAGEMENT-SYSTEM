# ─────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────
APP_NAME="Gateway ICT Polytechnic Saapade Alumni Portal"
# local | production — controls error verbosity, config caching behavior.
APP_ENV=local
# Generate with `php artisan key:generate --show` and set as a real secret
# in Railway's dashboard for production. Never commit an actual key.
APP_KEY=
# false in production — true leaks stack traces to API responses.
APP_DEBUG=true
# The backend's own public URL. Local: http://localhost:8000
# Production: your Railway service URL, e.g. https://gateway-alumni-api.up.railway.app
APP_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────
# CROSS-DOMAIN AUTH & CORS (Vercel frontend <-> Railway backend)
# ─────────────────────────────────────────────────────────────────────────
# The deployed frontend's exact origin (scheme + host, no trailing slash).
# Read by config/cors.php to build the CORS allowlist. Auth itself uses
# Sanctum bearer tokens (see AuthController), not cookies, specifically
# because Vercel and Railway don't share a parent domain — but CORS still
# needs to be correct for the browser to allow the request at all.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app (or your custom domain)
FRONTEND_URL=http://localhost:3000

# Only relevant if you fall back to cookie-based Sanctum SPA auth for a
# same-origin/local-dev setup. Not used by the deployed bearer-token flow.
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

LOG_CHANNEL=stack
# Railway captures stdout/stderr directly — 'error' keeps noise down without
# writing large log files inside the container's ephemeral filesystem.
LOG_LEVEL=error

# ─────────────────────────────────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────────────────────────────────────
# Get these from Supabase -> Project Settings -> Database.
# Two connection modes Supabase offers — pick based on your workload:
#
#   Direct connection (port 5432): use for migrations/seeders (this app's
#   Docker release step) — supports prepared statements, no pooling limits
#   on schema-changing operations.
#
#   Transaction pooler / PgBouncer (port 6543, host has "pooler" in it):
#   use for the running application's normal request traffic — Supabase's
#   free/small tiers cap direct connections low, and a web app opening a
#   connection per request will exhaust that fast. See SUPABASE.md for the
#   exact connection string Supabase gives you and how to point each use
#   case at the right port.
#
# sslmode=require is mandatory — Supabase rejects unencrypted connections.
DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
# 'sync' is the safe default for a single small Railway instance with no
# separate worker process. Switch to 'database' + run `php artisan
# queue:work` as a second Railway service only if you add a queue worker.
QUEUE_CONNECTION=sync

# ─────────────────────────────────────────────────────────────────────────
# MAIL — needed for password reset and (if you wire it up) email
# notification delivery. Any SMTP provider works; Supabase does not
# provide mail.
# ─────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@gatewaypolysaapade.edu.ng"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────
# FILE STORAGE — profile photos, event galleries, generated reports.
# Railway's container filesystem is ephemeral (wiped on every redeploy/
# restart), so 'local' storage is NOT safe for anything user-uploaded in
# production. Use Supabase Storage (S3-compatible) or another S3 provider.
# ─────────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=s3
# Supabase Storage -> Project Settings -> Storage -> S3 connection details.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=alumni-portal-uploads
AWS_ENDPOINT=https://xxxxxxxxxxxx.supabase.co/storage/v1/s3
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─────────────────────────────────────────────────────────────────────────
# SEED DATA
# ─────────────────────────────────────────────────────────────────────────
# Password for the initial super admin account created by AdminUserSeeder.
# Set a real value via Railway's env vars before running the seeder in
# production — change it immediately after first login either way.
SUPER_ADMIN_SEED_PASSWORD=ChangeMe#12345
